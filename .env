# ============================================================
# CreatifPro – Environment Variables
# Replace the placeholder values below with your own secrets
# before deploying. For local overrides, use a .env.local file
# (which is git-ignored and takes precedence).
# ============================================================

# PostgreSQL
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# Spring Boot datasource (must match the PostgreSQL values above – same credential)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=changeme_strong_password

# JVM tuning (optional – override the Dockerfile default)
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0
