# ============================================================
# CreatifPro – Environment Variables Template
# Copy this file to `.env` and fill in your values.
# NEVER commit the `.env` file to source control.
# ============================================================

# PostgreSQL
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# Spring Boot datasource (must match the PostgreSQL values above – same credential)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=changeme_strong_password

# JVM tuning (optional – override the Dockerfile default)
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0
